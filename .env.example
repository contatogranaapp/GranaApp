# ============================================================
# GRANA — Variáveis de Ambiente
# Renomeie este arquivo para .env.local e preencha os valores
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Acesse: https://supabase.com → seu projeto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...     # NUNCA exponha no front!

# ── Anthropic (Claude AI) ─────────────────────────────────────
# Acesse: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Stripe ────────────────────────────────────────────────────
# Acesse: https://dashboard.stripe.com → Developers
# Em desenvolvimento use as chaves de TESTE (sk_test_...)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...            # ID do produto R$50/mês

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email - Resend ─────────────────────────────────────────────
# Acesse: https://resend.com → API Keys
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@grana.app
